clear all
close all
clc

function T = Tx(a)
    T = [a; 0; 0];
end
function T = Ty(b)
    T = [0; b; 0];
end
function T = Tz(d)
    T = [0; 0; d];
end
function T = Rx(theta)
    T = [ 1, 0, 0;
          0, cos(theta), -sin(theta);
          0, sin(theta), cos(theta) ];
end
function T = Ry(theta)
    T = [ cos(theta), 0, -sin(theta);
          0, 1, 0;
          sin(theta), 0, cos(theta) ];
end
function T = Rz(theta)
    T = [ cos(theta), -sin(theta), 0;
          sin(theta), cos(theta),  0;
          0, 0, 1; ];
end

e_x = [1; 0; 0];
e_y = [0; 1; 0];
e_z = [0; 0; 1];

Tx(0)

Rx(0)

Rz(pi/2)*e_x

Ry(pi/2)*e_x

Rx(pi/2)*e_y


L1 = 0;
theta1 = 0;

L2 = 1;
theta2 = pi/2;

L3 = 2;
theta3 = 0;

T_01 = [Rz(theta1), Tz(0); 0,0,0,1] * [Rz(0), Tz(L1); 0,0,0,1]
T_12 = [Ry(theta2), Tx(L2); 0,0,0,1]
T_23 = [Ry(theta3), Tx(L3); 0,0,0,1]


T_02 = T_01 * T_12
T_03 = T_02 * T_23

p0 = [1;1;0]

p1 = head(T_01*[p0;1], 3)

p2 = head(T_02*[p0;1], 3)

p3 = head(T_03*[p0;1], 3)

